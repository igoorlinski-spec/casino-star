generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  nickname         String           @unique @db.VarChar(10)
  passwordHash     String
  tokens           Int              @default(0)
  skinColor        String           @default("light")
  hairStyle        String           @default("short")
  characterCreated Boolean          @default(false)
  createdAt        DateTime         @default(now())
  hasBag           Boolean          @default(false)
  tinderHearts     Int              @default(0)
  tinderBadge      String?          @default("")
  dollars          Float            @default(0.0)
  burgerBonusLevel Int              @default(0)
  burgerMultLevel  Int              @default(0)
  bagInventory     BagInventory[]
  inventory        Inventory[]
  matchesAsP1      MatchHistory[]   @relation("Player1Matches")
  matchesAsP2      MatchHistory[]   @relation("Player2Matches")
  matchesWon       MatchHistory[]   @relation("WinnerMatches")
  playerHouse      PlayerHouse?
  playerNeeds      PlayerNeeds?
  playerStats      PlayerStats?
  stocks           StockHolding[]
  businesses       UserBusiness[]
  cars             UserCar[]
  realEstates      UserRealEstate[]
}

model PlayerNeeds {
  userId    String   @id
  sleep     Float    @default(100)
  hunger    Float    @default(100)
  hydration Float    @default(100)
  updatedAt DateTime @updatedAt
  happiness Float    @default(100)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BagInventory {
  id       Int      @id @default(autoincrement())
  userId   String
  itemName String
  quantity Int      @default(0)
  addedAt  DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemName])
}

model House {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  price        Int
  sleepBonus   Float
  hasFridge    Boolean
  hasTap       Boolean
  freeFood     Boolean
  playerHouses PlayerHouse[]
}

model PlayerHouse {
  userId      String   @id
  houseId     Int
  purchasedAt DateTime @default(now())
  house       House    @relation(fields: [houseId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Inventory {
  id       Int    @id @default(autoincrement())
  userId   String
  itemName String
  quantity Int    @default(0)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemName])
}

model PlayerStats {
  userId             String @id
  blackjackWinsTotal Int    @default(0)
  rankedWins         Int    @default(0)
  rankedLosses       Int    @default(0)
  gamesPlayed        Int    @default(0)
  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchHistory {
  id          Int      @id @default(autoincrement())
  player1Id   String
  player2Id   String?
  gameType    String
  winnerId    String?
  tokensDelta Int
  playedAt    DateTime @default(now())
  player1     User     @relation("Player1Matches", fields: [player1Id], references: [id])
  player2     User?    @relation("Player2Matches", fields: [player2Id], references: [id])
  winner      User?    @relation("WinnerMatches", fields: [winnerId], references: [id])
}

model UserBusiness {
  id              Int      @id @default(autoincrement())
  userId          String
  businessId      String
  level           Int      @default(1)
  hasManager      Boolean  @default(false)
  lastCollectedAt DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model UserRealEstate {
  id              Int      @id @default(autoincrement())
  userId          String
  estateId        String
  lastCollectedAt DateTime @default(now())
  purchasedAt     DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, estateId])
}

model UserCar {
  id          Int      @id @default(autoincrement())
  userId      String
  carId       String
  purchasedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}

model Stock {
  id            String         @id
  name          String
  emoji         String
  price         Float
  initialPrice  Float
  lastUpdatedAt DateTime       @default(now())
  holdings      StockHolding[]
}

model StockHolding {
  id          Int      @id @default(autoincrement())
  userId      String
  stockId     String
  shares      Float
  avgBuyPrice Float
  boughtAt    DateTime @default(now())
  stock       Stock    @relation(fields: [stockId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
}
